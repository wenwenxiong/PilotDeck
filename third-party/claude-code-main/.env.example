# Copy to .env in this directory and fill in real values.
#   cp .env.example .env
# Never commit .env.

# -----------------------------------------------------------------------------
# Upstream: OpenAI-compatible API (proxy.ts forwards Anthropic → this endpoint)
# -----------------------------------------------------------------------------
# No trailing /v1 — proxy.ts appends /v1/chat/completions
OPENAI_BASE_URL=https://openrouter.ai/api
OPENAI_API_KEY=sk-or-v1-replace-me

# Local Anthropic-shim proxy port (proxy.ts listens here)
PROXY_PORT=18080

# -----------------------------------------------------------------------------
# Claude Code CLI (bun): talks to the local proxy by default
# -----------------------------------------------------------------------------
# Usually the same value as OPENAI_API_KEY (proxy authenticates upstream).
ANTHROPIC_API_KEY=sk-or-v1-replace-me

# If unset, start.sh sets this to http://127.0.0.1:$PROXY_PORT
# ANTHROPIC_BASE_URL=http://127.0.0.1:18080

# Must match a model id your upstream actually serves.
ANTHROPIC_MODEL=claude-opus-4-6

# Avoid official OAuth overriding key mode
# (start.sh always unsets ANTHROPIC_AUTH_TOKEN before exec)

DISABLE_TELEMETRY=1
