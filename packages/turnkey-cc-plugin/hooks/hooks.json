{
  "_comment": "turnkey-cc-plugin hooks. Claude Code plugin hook format. Maps to cursor-prototype hooks: beforeSubmitPrompt -> UserPromptSubmit, afterAgentResponse -> Stop + PostToolUse (for finer-grained budget tracking). Failures must be non-blocking per Obs-A. PostToolUse also captures into inbox so substep-aggregator can derive develop substep counts.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/turnkey-capture.js --event UserPromptSubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/turnkey-capture.js --event Stop"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/turnkey-budget.js --event Stop"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/turnkey-substep-aggregator.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/turnkey-capture.js --event PostToolUse"
          },
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/turnkey-budget.js --event PostToolUse"
          }
        ]
      }
    ]
  }
}
